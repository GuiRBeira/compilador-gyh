{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "GYH",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [{
                "name": "comment.line.number-sign.gyh",
                "match": "#.*$"
            }]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.gyh",
                "match": "\\b(DEC|PROG|LER|IMPRIMIR|SE|ENTAO|SENAO|ENQTO|INI|FIM)\\b"
            },
            {
                "name": "storage.type.gyh",
                "match": "\\b(INT|REAL)\\b"
            },
            {
                "name": "keyword.operator.logical.gyh",
                "match": "\\b(E|OU)\\b"
            }]
        },
        "strings": {
            "patterns": [{
                "name": "string.quoted.double.gyh",
                "begin": "\"",
                "end": "\"",
                "patterns": [
                    {
                        "name": "constant.character.escape.gyh",
                        "match": "\\\\."
                    }
                ]
            }]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.gyh",
                    "match": "\\b[0-9]*\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.gyh",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.gyh",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.delimiter.gyh",
                    "match": ":"
                },
                {
                    "name": "keyword.operator.comparison.gyh",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.gyh",
                    "match": "(\\+|\\-|\\*|\\/)"
                }
            ]
        }
    },
    "scopeName": "source.gyh"
}
